  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  key        String
  value      Json
  updatedAt  DateTime @updatedAt

  @@unique([locationId, key])
  @@index([locationId])
}

model UserLocation {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  isPrimary  Boolean  @default(false)

  @@unique([userId, locationId])
  @@index([userId])
  @@index([locationId])
}

model VideoCharacter {
  id                    String   @id @default(uuid())
  name                  String
  description           String?
  // Source video/image stored locally
  videoUrl              String?  // local /uploads/video-studio/characters/xxx.mp4
  imageUrl              String?  // local /uploads/video-studio/characters/xxx.jpg
  thumbnailUrl          String?  // local thumbnail
  // Provider IDs for regeneration
  heygenAvatarId        String?
  heygenTalkingPhotoId  String?
  heygenVoiceId         String?
  heygenEmotion         String?
  hedraImageUrl         String?  // URL Hedra uses (can be remote)
  // Generation defaults
  defaultActionPrompt   String   @default("")
  defaultAspectRatio    String   @default("9:16")
  // Metadata
  provider              String   @default("hedra")  // heygen, hedra, kling, upload
  tags                  String[] @default([])
  notes                 String?
  isBolt                Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([provider])
  @@index([isBolt])
}

model VideoScene {
  id            String   @id @default(uuid())
  name          String
  prompt        String?  // The Kling prompt used to generate it
  // Stored locally
  videoUrl      String?  // local /uploads/video-studio/scenes/xxx.mp4
  thumbnailUrl  String?
  // Metadata
  aspectRatio   String   @default("16:9")  // 16:9, 9:16, 1:1
  durationSec   Float    @default(5)
  source        String   @default("kling")  // kling, heygen, upload
  tags          String[] @default([])
  notes         String?
  // Original external URL (may expire)
  originalUrl   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([source])
  @@index([aspectRatio])
}

