// ─── Apprentice Training Center ─────────────────────────────

model TrainingCourse {
  id          String           @id @default(uuid())
  slug        String           @unique
  title       String
  description String           @db.Text
  category    TrainingCategory
  year        Int              @default(1) // 1-4 apprenticeship year
  semester    Int              @default(1) // 1 or 2
