  @@index([type])
  @@index([memberId])
}

model JarvisHealthLog {
  id        String   @id @default(cuid())
  type      String   // workout, weight, sleep, water, food, mood, etc.
  value     Float?   // numeric value (lbs, hours, oz, etc.)
  unit      String?  // lbs, hours, oz, reps, miles, etc.
  notes     String?
  loggedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([type])
  @@index([loggedAt])
}

model JarvisGoal {
  id           String    @id @default(cuid())
  title        String
  category     String    // business, health, financial, family, personal, home, other
  targetValue  Float?
  targetUnit   String?
  currentValue Float?    @default(0)
  deadline     DateTime?
  why          String?
  milestones   String?
  notes        String?
  status       String    @default("active") // active, completed, abandoned
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([deadline])
}

model JarvisContact {
  id              String    @id @default(cuid())
  name            String
  relationship    String
  phone           String?
  email           String?
  birthday        String?
  company         String?
  notes           String?
  lastContactDate DateTime?
  followUpDate    DateTime?
  followUpReason  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([name])
  @@index([relationship])
  @@index([followUpDate])
}

model JarvisShoppingItem {
  id             String    @id @default(cuid())
  item           String
  quantity       String    @default("1")
  store          String?
  category       String?
  listType       String    // grocery, wishlist, orders
  completed      Boolean   @default(false)
  completedAt    DateTime?
  estimatedPrice Float?
  priority       String?
  url            String?
  notes          String?
  createdAt      DateTime  @default(now())

  @@index([listType])
  @@index([completed])
  @@index([category])
}

model JarvisMaintenanceLog {
  id            String   @id @default(cuid())
  task          String
  system        String   // hvac, electrical, plumbing, exterior, appliances, general
  completedDate DateTime @default(now())
  nextDueDate   DateTime
  notes         String?
  cost          Float?   @default(0)
  createdAt     DateTime @default(now())

  @@index([system])
  @@index([nextDueDate])
}

// ─── Lux Autonomy ────────────────────────────────────────────────────────────

model LuxActionLog {
  id          String    @id @default(cuid())
  toolName    String
  toolInput   Json
  result      String?
  stakes      String    // read | low | medium | high | critical
  decision    String    // act_silent | act_notify | act_undo | confirm_first | always_confirm
  status      String    // pending | executed | confirmed | rejected | undone | expired
  channel     String?
  autonomous  Boolean   @default(false)
  rationale   String?
  undoable    Boolean   @default(false)
  undoData    Json?
  expiresAt   DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([toolName])
  @@index([autonomous])
}

model LuxCalibration {
  id        String   @id @default(cuid())
  toolName  String   @unique
  category  String
  approved  Int      @default(0)
  rejected  Int      @default(0)
  skipped   Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([toolName])
}

model LuxAutonomyConfig {
  id               String   @id @default("singleton")
  paused           Boolean  @default(false)
  safeMode         Boolean  @default(false)
  notifyAll        Boolean  @default(false)
  dollarThreshold  Float    @default(500)
  confirmWindowMin Int      @default(10)
  updatedAt        DateTime @updatedAt
}

// ─── Customer Interaction Timeline ──────────────────────────────
model CustomerInteraction {
  id           String   @id @default(uuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type         String
  channel      String?
  direction    String?

  subject      String?
  body         String?  @db.Text
  amount       Float?

  jobId        String?
  invoiceId    String?
  estimateId   String?

  technicianId  String?
  createdByName String?

  recordedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([customerId, recordedAt])
  @@index([customerId, type])
  @@index([jobId])
  @@index([invoiceId])
  @@index([recordedAt])
}

// ─── Supplier Purchase History ───────────────────────────────────
model SupplierPurchase {
  id           String   @id @default(uuid())

  supplier     String
  invoiceRef   String?
  purchaseDate DateTime @default(now())

  jobId        String?
  jobNumber    String?

  totalAmount  Float

  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        SupplierPurchaseItem[]

  @@index([supplier])
  @@index([purchaseDate])
  @@index([jobId])
}

model SupplierPurchaseItem {
  id           String @id @default(uuid())
  purchaseId   String
  purchase     SupplierPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  description  String
  partNumber   String?
  category     String?
  quantity     Float    @default(1)
  unit         String   @default("each")
  unitCost     Float
  totalCost    Float

  @@index([purchaseId])
  @@index([description])
  @@index([partNumber])
}

// ─── Supplier Price Tracking ──────────────────────────────────────
// Tracks unit prices for specific items across suppliers.
// Used for price comparison and trend alerting.

model SupplierPrice {
  id          String   @id @default(uuid())
  supplier    String
  itemName    String
  partNumber  String?
  unitPrice   Float
  unit        String   @default("each")
  notes       String?
  loggedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([supplier])
  @@index([itemName])
  @@index([loggedAt])
}

// ─── Job Suppression Log ─────────────────────────────────────────────────────
// Records WO- jobs that were suppressed at booking time because a matching
// WZ- job already existed. Temporary until BoltOPX iOS replaces Workiz.

model JobSuppressionLog {
  id                  String   @id @default(uuid())
  suppressedJobNumber String   // The WO- number that would have been created
  matchedWzJob        String   // The WZ- job it matched against
  customerName        String?
  address             String?
  reason              String   // e.g. "address_match" | "customer_name_match"
  createdAt           DateTime @default(now())

  @@index([createdAt])
  @@index([matchedWzJob])
}
