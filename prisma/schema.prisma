  videoWatched    Boolean   @default(false)
  watchedAt       DateTime?
  quizScore       Int?
  quizAttempts    Int       @default(0)
  quizCompletedAt DateTime?
  timeSpentMins   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  technicianId String
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       TrainingLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([technicianId, lessonId])
  @@index([technicianId])
  @@index([lessonId])
}

// ─── Accounting ───────────────────────────────────────────

model Account {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  type          String    // asset, liability, equity, revenue, cogs, expense
  subType       String?
  parentId      String?
  parent        Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[] @relation("AccountHierarchy")
  isActive      Boolean   @default(true)
  isSystem      Boolean   @default(false)
  description   String?
  normalBalance String    @default("debit")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  journalLines  JournalLine[]
  bankAccounts  BankAccount[]

  @@index([type])
  @@index([parentId])
  @@index([code])
}

model JournalEntry {
  id          String   @id @default(uuid())
  entryNumber String   @unique
  date        DateTime
  memo        String?
  source      String   @default("manual")
  sourceId    String?
  isAdjusting Boolean  @default(false)
  isReversing Boolean  @default(false)
  status      String   @default("posted")
  createdBy   String?
  approvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines JournalLine[]

  @@index([date])
  @@index([source, sourceId])
  @@index([status])
}

model JournalLine {
  id             String       @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Float        @default(0)
  credit         Float        @default(0)
  memo           String?

  @@index([journalEntryId])
  @@index([accountId])
}

model PlaidConnection {
  id               String    @id @default(uuid())
  institutionId    String
  institutionName  String
  accessToken      String
  itemId           String    @unique
  status           String    @default("active")
  consentExpiresAt DateTime?
  lastSyncCursor   String?
  lastSyncAt       DateTime?
  errorCode        String?
  errorMessage     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  bankAccounts BankAccount[]

  @@index([status])
}

model BankAccount {
  id                String          @id @default(uuid())
  plaidConnectionId String
  plaidConnection   PlaidConnection @relation(fields: [plaidConnectionId], references: [id], onDelete: Cascade)
  plaidAccountId    String          @unique
  name              String
  officialName      String?
  mask              String?
  type              String
  subType           String?
  currentBalance    Float?
  availableBalance  Float?
  accountId         String?
  account           Account?        @relation(fields: [accountId], references: [id])
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  transactions BankTransaction[]

  @@index([plaidConnectionId])
  @@index([accountId])
}

model BankTransaction {
  id                 String      @id @default(uuid())
  bankAccountId      String
  bankAccount        BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  plaidTransactionId String      @unique
  date               DateTime
  name               String
  amount             Float
  category           String[]
  merchantName       String?
  pending            Boolean     @default(false)
  status             String      @default("unreviewed")
  accountId          String?
  journalEntryId     String?
  splitLines         Json?
  aiConfidence       Float?
  aiReason           String?
  vendorId           String?
  receiptUrl         String?
  notes              String?
  reviewedBy         String?
  reviewedAt         DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([bankAccountId, date])
  @@index([status])
  @@index([date])
  @@index([plaidTransactionId])
  @@index([vendorId])
}

model Vendor {
  id               String   @id @default(uuid())
  name             String
  plaidNames       String[] @default([])
  defaultAccountId String?
  phone            String?
  email            String?
  address          String?
  notes            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([name])
}

model CategorizationRule {
  id         String   @id @default(uuid())
  pattern    String
  matchType  String   @default("contains")
  accountId  String
  vendorId   String?
  memo       String?
  confidence Float    @default(1.0)
  isAI       Boolean  @default(false)
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([pattern])
}

model Reconciliation {
  id                    String    @id @default(uuid())
  bankAccountId         String
  periodStart           DateTime
  periodEnd             DateTime
  statementBalance      Float
  bookBalance           Float
  difference            Float     @default(0)
  status                String    @default("in_progress")
  reconciledBy          String?
  completedAt           DateTime?
  notes                 String?
  matchedTransactionIds Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([bankAccountId, periodEnd])
  @@index([status])
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  keyHash    String
  keyPrefix  String
  scopes     String[]  @default([])
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([keyHash])
  @@index([keyPrefix])
}

// ─── Multi-Location / Franchise ──────────────────────────────────

model Location {
  id              String    @id @default(uuid())
  name            String
  slug            String    @unique
  address         String?
  city            String?
  state           String?
  zip             String?
  phone           String?
  email           String?
  timezone        String    @default("America/New_York")
  latitude        Float?
  longitude       Float?
  serviceRadius   Float     @default(50)
  isActive        Boolean   @default(true)
  isDefault       Boolean   @default(false)
  // Franchise
  isFranchise     Boolean   @default(false)
  franchiseOwnerId String?
  billingEmail    String?
  brandOverrides  Json?
  createdAt       DateTime  @default(now())
